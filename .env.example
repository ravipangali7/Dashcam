# Copy to .env and adjust.
# This project keeps `.env` in git — commit and push it with other changes.

# Verbose console debugging (hex previews, per-frame parse, HTTP bodies)
# DEBUG=1
# JT808_DEBUG=true

# JT/T 808 signalling (terminal connects here)
# 0.0.0.0 = reachable from the internet (scanners may connect and reset — ECONNRESET is normal).
# Use HOST=127.0.0.1 for local-only, or firewall PORT to your SIM/VPN IPs.
HOST=0.0.0.0
PORT=4000
JT808_PROTOCOL=2013
# JT808_PROTOCOL=2019

# Optional terminal handling (reply 0x8100 after 0x0100 — on for typical dashcam registration)
AUTO_REPLY_REGISTER=true
REGISTER_AUTH_CODE=AUTH
# If terminal sends 0x0102 then disconnects, try AUTO_PLATFORM_GENERAL_ACK=true (sends 0x8001 for auth/location).
AUTO_PLATFORM_GENERAL_ACK=true

# --- Streaming (0x9101 is still normal JT808-2013 framing on the signalling socket) ---
# MEDIA_PUBLIC_HOST must be reachable from the vehicle (not 127.0.0.1 on cellular).
# Enable HTTP to POST /jt808/stream/request with JSON { "phone": "015770066239" } (12-digit SIM key from logs).
# Media TCP receives raw bytes; use ffmpeg/VLC on MEDIA_RECORD_DIR files or add a demuxer later.
MEDIA_HOST=0.0.0.0
MEDIA_PORT=10700
MEDIA_PUBLIC_HOST=0.0.0.0
MEDIA_UDP_PORT=0
MEDIA_RECORD_DIR=
# After first 0x0102 on a connection, send one 0x9101 automatically (optional).
AUTO_STREAM_9101=false
STREAM_CHANNEL_NO=1
STREAM_DATA_TYPE=1
STREAM_STREAM_TYPE=0

HTTP_CONTROL_HOST=0.0.0.0
HTTP_CONTROL_PORT=0
