# Copy to .env and adjust.
# This project keeps `.env` in git — commit and push it with other changes.

# Verbose console debugging (hex previews, per-frame parse, HTTP bodies)
# DEBUG=1
# JT808_DEBUG=true

# JT/T 808 signalling (terminal connects here)
# 0.0.0.0 = reachable from the internet (scanners may connect and reset — ECONNRESET is normal).
# Use HOST=127.0.0.1 for local-only, or firewall PORT to your SIM/VPN IPs.
HOST=0.0.0.0
PORT=4000
JT808_PROTOCOL=2013
# JT808_PROTOCOL=2019

# Optional terminal handling (reply 0x8100 after 0x0100 — on for typical dashcam registration)
AUTO_REPLY_REGISTER=true
REGISTER_AUTH_CODE=AUTH
# If terminal sends 0x0102 then disconnects, try AUTO_PLATFORM_GENERAL_ACK=true (sends 0x8001 for auth/location).
AUTO_PLATFORM_GENERAL_ACK=true

# --- Streaming (0x9101 is still normal JT808-2013 framing on the signalling socket) ---
# MEDIA_PUBLIC_HOST must be reachable from the vehicle (not 127.0.0.1 on cellular).
# Enable HTTP to POST /jt808/stream/request with JSON { "phone": "015770066239" } (12-digit SIM key from logs).
# Media TCP receives raw bytes; use ffmpeg/VLC on MEDIA_RECORD_DIR files or add a demuxer later.
MEDIA_HOST=0.0.0.0
MEDIA_PORT=10700
# Public IP or DNS the SIM can reach (same host you Test-NetConnection to for MEDIA_PORT)
MEDIA_PUBLIC_HOST=82.180.145.220
MEDIA_UDP_PORT=0
MEDIA_RECORD_DIR=
# After first 0x0102 on a connection, send one 0x9101 automatically (optional).
AUTO_STREAM_9101=true
STREAM_CHANNEL_NO=1
STREAM_DATA_TYPE=1
STREAM_STREAM_TYPE=0

HTTP_CONTROL_HOST=0.0.0.0
HTTP_CONTROL_PORT=0

# --- MediaMTX (RTSP/HLS gateway for viewers; device still pushes raw bytes to Node MEDIA_PORT) ---
# Start gateway: npm run mediamtx:up  (Docker) or run mediamtx with -config ./mediamtx/mediamtx.yml
# Pipe Node’s TCP payload into ffmpeg → RTSP publish (device format must match ffmpeg demuxer).
# MEDIAMTX_FFMPEG_ENABLED=true
# Publish URL: static, or use {phone} for per-terminal paths (matched by JT808 client IP → last phone on that IP).
# MEDIAMTX_PUBLISH_URL=rtsp://127.0.0.1:8554/dashcam
# MEDIAMTX_PUBLISH_URL_TEMPLATE=rtsp://127.0.0.1:8554/dashcam/{phone}
# MEDIAMTX_PUBLISH_URL_TEMPLATE=rtsp://127.0.0.1:8554/{phone}
# MEDIAMTX_UNKNOWN_PHONE_LABEL=unknown
# MEDIAMTX_FFMPEG_BIN=ffmpeg
# Optional demuxer hint if probe fails: MEDIAMTX_FFMPEG_INPUT_FORMAT=mpegts
# Extra argv before -i pipe:0, pipe-separated: MEDIAMTX_FFMPEG_EXTRA_BEFORE_INPUT=-probesize|5000000
# VLC / control API hints (set one of: FFMPEG enabled, MEDIAMTX_PLAYBACK_URL, or MEDIAMTX_PLAYBACK_HINTS=true):
# MEDIAMTX_PLAYBACK_HINTS=true
# MEDIAMTX_PLAYBACK_URL=rtsp://82.180.145.220:8554/dashcam
# When using {phone} publish template, VLC URLs use {host} and {phone} (defaults match dashcam/{phone}):
# MEDIAMTX_PLAYBACK_URL_TEMPLATE=rtsp://{host}:8554/dashcam/{phone}
# MEDIAMTX_PLAYBACK_PATH_TEMPLATE=dashcam/{phone}
# MEDIAMTX_PLAYBACK_HOST=82.180.145.220
# MEDIAMTX_RTSP_PORT=8554
# MEDIAMTX_HLS_PORT=8888
# MEDIAMTX_PATH=dashcam
