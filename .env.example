# Copy to .env and adjust.
# This project keeps `.env` in git — commit and push it with other changes.

# Verbose console debugging (hex previews, per-frame parse, HTTP bodies)
# DEBUG=1
# JT808_DEBUG=true

# JT/T 808 signalling (terminal connects here)
# 0.0.0.0 = reachable from the internet (scanners may connect and reset — ECONNRESET is normal).
# Use HOST=127.0.0.1 for local-only, or firewall PORT to your SIM/VPN IPs.
HOST=0.0.0.0
PORT=4000
JT808_PROTOCOL=2013
# JT808_PROTOCOL=2019

# Optional terminal handling
AUTO_REPLY_REGISTER=false
REGISTER_AUTH_CODE=AUTH
AUTO_PLATFORM_GENERAL_ACK=false

# JT/T 1078 style media: terminal opens a separate TCP session here after 0x9101
MEDIA_HOST=0.0.0.0
MEDIA_PORT=10700
# IP/hostname placed inside 0x9101 (must be reachable from the vehicle network)
MEDIA_PUBLIC_HOST=127.0.0.1
MEDIA_UDP_PORT=0
# Save inbound media bytes to this folder (optional)
MEDIA_RECORD_DIR=

# REST hooks to send 0x9101 / 0x9102 to a connected terminal (0 = disabled)
HTTP_CONTROL_HOST=0.0.0.0
HTTP_CONTROL_PORT=0
