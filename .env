# TCP server bind (JT808 signalling)
HOST=0.0.0.0
PORT=4000
JT808_PROTOCOL=2013

# JT1078 media sink (raw TCP; terminal connects after 0x9101)
MEDIA_HOST=0.0.0.0
MEDIA_PORT=10700
MEDIA_PUBLIC_HOST=127.0.0.1
MEDIA_UDP_PORT=0

# HTTP control API (set >0 to enable, e.g. 18080)
HTTP_CONTROL_HOST=0.0.0.0
HTTP_CONTROL_PORT=0
